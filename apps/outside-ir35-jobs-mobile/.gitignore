# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/

# Native
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Google Play service-account key (used by eas.json submit.production.android).
# Never commit it.
google-service-account.json
# Firebase / Google Sign-In native config (if added later)
GoogleService-Info.plist
google-services.json

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# pnpm
.pnpm-debug.log*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

expo-env.d.ts
app-example

# Expo prebuild — regenerated by `expo prebuild --clean`, never committed.
ios/
android/

*.zip
*.apk
*.ipa
