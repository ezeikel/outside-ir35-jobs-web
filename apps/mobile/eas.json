{
  "cli": {
    "promptToConfigurePushNotifications": false,
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "ios": { "resourceClass": "m-medium" },
      "android": { "image": "latest" }
    },
    "development": {
      "extends": "base",
      "environment": "development",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": { "simulator": true },
      "env": { "EXPO_PUBLIC_ENVIRONMENT": "development" },
      "autoIncrement": false
    },
    "preview": {
      "extends": "base",
      "environment": "preview",
      "distribution": "internal",
      "channel": "preview",
      "android": { "buildType": "apk" },
      "ios": { "simulator": false },
      "env": { "EXPO_PUBLIC_ENVIRONMENT": "preview" },
      "autoIncrement": true
    },
    "production": {
      "extends": "base",
      "environment": "production",
      "distribution": "store",
      "channel": "production",
      "env": { "EXPO_PUBLIC_ENVIRONMENT": "production" },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "developer@chewybytes.com",
        "appleTeamId": "HGX827L49J",
        "ascAppId": "6784110879"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
