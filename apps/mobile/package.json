{
  "name": "@outside-ir35-jobs/mobile",
  "main": "./index.js",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "git clean -xdf .expo node_modules",
    "start": "expo start",
    "dev": "expo start --ios",
    "dev:android": "expo start --android",
    "dev:ios": "expo start --ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "prebuild:android": "expo prebuild --platform android --clean",
    "ios": "expo run:ios --no-build-cache",
    "android": "expo run:android --no-build-cache",
    "build:ios": "pnpm prebuild:ios && pnpm ios",
    "build:android": "pnpm prebuild:android && pnpm android",
    "build": "expo export",
    "eas:build:development": "eas build --profile development",
    "eas:build:preview": "eas build --profile preview",
    "eas:build:production": "eas build --profile production",
    "eas:release:ios": "eas build --profile production --platform ios --auto-submit",
    "eas:release:android": "eas build --profile production --platform android --auto-submit",
    "eas:submit:production": "eas submit --profile production",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "expo lint",
    "check-types": "tsc --noEmit",
    "env:pull": "eas env:pull --environment development",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@expo-google-fonts/geist-mono": "^0.4.2",
    "@expo-google-fonts/instrument-serif": "^0.4.1",
    "@expo-google-fonts/inter-tight": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-native-fontawesome": "^1.0.0",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/app": "^24.1.1",
    "@react-native-firebase/messaging": "^24.1.1",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@sentry/react-native": "~8.12.0",
    "@shopify/flash-list": "2.0.2",
    "@swmansion/react-native-bottom-sheet": "0.10.1",
    "@tanstack/react-query": "^5.62.0",
    "axios": "^1.7.8",
    "expo": "~56.0.5",
    "expo-apple-authentication": "~56.0.4",
    "expo-application": "^56.0.3",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.17",
    "expo-constants": "~56.0.16",
    "expo-dev-client": "~56.0.16",
    "expo-device": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-image-picker": "~56.0.18",
    "expo-linking": "~56.0.12",
    "expo-router": "~56.2.7",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.17",
    "expo-web-browser": "~56.0.5",
    "nativewind": "5.0.0-preview.2",
    "posthog-react-native": "^4.46.19",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-css": "3.0.4",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-purchases": "^9.15.2",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "~0.8.3",
    "sonner-native": "^0.25.1",
    "zod": "^3.25.76",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@evennit/notifee-expo-plugin": "^3.8.0",
    "@tailwindcss/postcss": "4.1.18",
    "@tanstack/eslint-plugin-query": "^5.61.6",
    "@types/node": "^22.10.2",
    "@types/react": "19.2.14",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "postcss": "^8",
    "prettier": "^3.4.1",
    "tailwindcss": "4.1.18",
    "typescript": "~6.0.3",
    "vitest": "^3.2.6"
  }
}
