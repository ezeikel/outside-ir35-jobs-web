{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "db:generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "ANTHROPIC_API_KEY",
        "AUTH_SECRET",
        "COMPANIES_HOUSE_API_KEY",
        "CRON_SECRET",
        "DATABASE_URL",
        "DATABASE_URL_UNPOOLED",
        "FONTAWESOME_NPM_AUTH_TOKEN",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "GOOGLE_MAPS_API_KEY",
        "HMRC_CLIENT_ID",
        "HMRC_CLIENT_SECRET",
        "NEXT_AUTH_SECRET",
        "NEXTAUTH_URL",
        "NEXT_PUBLIC_SANITY_API_VERSION",
        "NEXT_PUBLIC_SANITY_DATASET",
        "NEXT_PUBLIC_SANITY_PROJECT_ID",
        "OPENAI_API_KEY",
        "OUTSIDE_IR35_JOBS_WORKER_URL",
        "PERPLEXITY_API_KEY",
        "R2_ACCESS_KEY_ID",
        "R2_BUCKET",
        "R2_ENDPOINT",
        "R2_PUBLIC_URL",
        "R2_SECRET_ACCESS_KEY",
        "RESEND_API_KEY",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_DSN",
        "SHADOW_DATABASE_URL",
        "WORKER_SECRET"
      ]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "check-types": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "dependsOn": ["^build", "db:generate"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["db:generate", "^build"],
      "outputs": ["coverage/**"]
    },
    "db:generate": {
      "inputs": ["prisma/schema.prisma"],
      "outputs": ["src/generated/**"]
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:deploy": {
      "cache": false
    },
    "env:pull": {
      "cache": false
    }
  }
}
