{
  "name": "outside-ir35-jobs",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@outside-ir35/web",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@outside-ir35/web",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky",
    "postinstall": "prisma generate --schema=packages/db/prisma/schema.prisma"
  },
  "lint-staged": {
    "apps/outside-ir35-jobs-web/**/*.{ts,tsx}": [
      "cd apps/outside-ir35-jobs-web && tsc --noEmit"
    ],
    "**/*.+(js|jsx|json|ts|tsx|html|md)": [
      "prettier --ignore-path .gitignore --write"
    ],
    "**/prisma/schema.prisma": [
      "pnpm exec prisma format --schema"
    ]
  },
  "devDependencies": {
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "turbo": "^2.5.6",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18",
      "@types/react-dom": "^18"
    }
  }
}
