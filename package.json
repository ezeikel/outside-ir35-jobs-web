{
  "name": "outside-ir35-jobs",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@outside-ir35-jobs/web",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@outside-ir35-jobs/web",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "format": "biome format --write .",
    "prepare": "husky",
    "postinstall": "prisma generate --schema=packages/db/prisma/schema.prisma"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "cd apps/web && tsc --noEmit"
    ],
    "**/*.{js,jsx,ts,tsx,json,jsonc,css}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "**/prisma/schema.prisma": [
      "pnpm exec prisma format --schema"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "turbo": "^2.5.6",
    "typescript": "~6.0.3"
  },
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.2.0",
      "@types/react-dom": "^19.2.0",
      "next": "16.1.0",
      "lightningcss": "1.30.1"
    }
  }
}
