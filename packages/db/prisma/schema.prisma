// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  JOB_SEEKER
  JOB_POSTER
  ADMIN
}

// Types of job posters
enum PosterType {
  RECRUITER
  DIRECT
}

enum SubscriptionType {
  BASIC
  PRO
}

// Which billing channel a subscription was created through.
enum SubscriptionProvider {
  STRIPE // Web subscriptions (Stripe Checkout)
  REVENUECAT // Mobile subscriptions (App Store / Play Store via RevenueCat)
}

enum WorkMode {
  REMOTE
  HYBRID
  ON_SITE
}

// What a JOB LISTING claims about IR35 — always the CLIENT's claim, never the
// platform's assertion. See docs/ir35-trust-model.md.
enum JobIR35Signal {
  CLIENT_INTENDS_OUTSIDE // "Client states this role is intended to be outside IR35"
  SDS_ISSUED // client confirms a Status Determination Statement has been issued
  SMALL_CLIENT_EXEMPT // small client → contractor's PSC self-determines
  CONTRACT_REVIEW_HELD // IR35-specialist contract review on file (poster-supplied)
  UNKNOWN // aggregated/scraped or unstated — first-class default
  INSIDE // for completeness/filtering; not our niche
}

// How a listing reached us — native (posted) vs aggregated (scraped, attributed).
enum JobSource {
  NATIVE
  AGGREGATED
}

// The contractor trust ladder (earned over time). Each tier = a specific,
// defensible set of checks, never a status guarantee. See docs/ir35-trust-model.md.
enum ContractorTrustTier {
  SELF_DECLARED // T0 — typed it, nothing verified
  IDENTITY_VERIFIED // T1 — Companies House + VAT auto-checks pass
  DOCUMENTS_ON_FILE // T2 — PI/PL/EL certs uploaded, insurer/limit/expiry tracked
  COMPLIANCE_CURRENT // T3 — all docs present AND in-date AND right-to-work confirmed
}

// Types of document in a contractor's compliance pack.
enum ContractorDocType {
  INCORPORATION
  VAT_CERTIFICATE
  PI_INSURANCE
  PL_INSURANCE
  EL_INSURANCE
  RIGHT_TO_WORK
  CV
  OTHER
}

// Live status of a single compliance document.
enum DocStatus {
  ON_FILE
  EXPIRING
  PENDING
  MISSING
  FAILED
}

// Payment state of a NATIVE job posting. Native posts are paid (£219); a job is
// only published (isActive=true) once Stripe confirms payment via webhook.
// AGGREGATED/scraped jobs are FREE (we never charge for index entries).
enum JobPaymentStatus {
  FREE // aggregated listings + any comped post — no payment required
  PENDING // native post created, awaiting Stripe checkout completion
  PAID // Stripe confirmed payment (webhook) — eligible to be published
}

model Job {
  id               String   @id @default(cuid())
  companyName      String
  position         String
  description      String
  keywords         String[]
  location         Json
  companyLogo      String?
  dayRate          Int[] // e.g. [100, 200] for a range or [100] for a fixed rate
  howToApply       String
  applicationEmail String
  workMode         WorkMode
  contractLength   Int? //  in days e.g. 30, 60, 90

  // IR35 — the CLIENT's claim about the role, never the platform's assertion.
  // Replaces the old verifiedIR35Status boolean (which asserted a status we have
  // no authority to assert). See docs/ir35-trust-model.md.
  ir35Signal               JobIR35Signal @default(UNKNOWN)
  classificationConfidence Int? // 0–100, set by the AI classifier for aggregated jobs

  // Aggregation — native posts vs scraped+attributed index entries.
  source          JobSource @default(NATIVE)
  // Link back to origin for aggregated listings. Unique so the worker can upsert
  // idempotently (re-running a scrape updates, never duplicates). NATIVE jobs
  // leave this null; Postgres treats nulls as distinct, so the constraint is safe.
  sourceUrl       String?   @unique
  rawDescription  String? // unparsed source text (aggregation pipeline)
  extractedSkills String[] // AI-extracted skills

  // Semantic search. Prisma can't type pgvector — see the migration for the
  // vector(1536) column + HNSW index; this field is raw-SQL only.
  embedding Unsupported("vector(1536)")?

  // Lexical (full-text) search. A GENERATED tsvector over position/skills/company/
  // description (weighted) + GIN index — auto-maintained, raw-SQL only. See the
  // migration. Fused with `embedding` semantic ranking via RRF in searchJobs.
  searchVector Unsupported("tsvector")?

  // The poster who owns this job (role = JOB_POSTER). Nullable: legacy/seed jobs
  // and future AGGREGATED (scraped) listings have no owner. SetNull so deleting a
  // poster doesn't delete their jobs.
  postedBy                User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId                  String?
  isActive                Boolean          @default(true)
  // Whether this job may appear on a PUBLIC board surface (default /jobs,
  // homepage, recommendations). Distinct from isActive (= live/not expired): an
  // explicit Inside-IR35 listing is kept in the DB — the /day-rates inside-vs-
  // outside benchmark needs it — but is NOT board-visible, because this is an
  // outside-IR35 board (docs/ir35-trust-model.md: INSIDE is "not our niche").
  // The worker sets this false for ir35Signal=INSIDE; defense-in-depth alongside
  // the web-side ir35Signal<>INSIDE gate. Benchmarks query on isActive only.
  boardVisible            Boolean          @default(true)
  // Payment state. Defaults to FREE so aggregated/scraped + legacy/seed jobs need
  // no change (we never charge for index entries). The native createJobPost action
  // overrides to PENDING and creates the job isActive=false; the Stripe webhook
  // flips it to PAID + isActive=true on checkout.session.completed.
  paymentStatus           JobPaymentStatus @default(FREE)
  // The Stripe Checkout Session id for a native WEB post, so the Stripe webhook
  // can reconcile the payment back to its job. Null for FREE jobs.
  stripeSessionId         String?          @unique
  // The RevenueCat transaction id for a native MOBILE post (StoreKit/Play, since
  // App Store rules forbid Stripe in-app). The RC webhook reconciles payment →
  // job the same way stripeSessionId does on web. DB is the source of truth for
  // payment across both providers (mirrors the premium Subscription dual-provider
  // model). Null for FREE + web/Stripe jobs.
  revenueCatTransactionId String?          @unique
  duration                Int              @default(30) // job post duration in days
  applications            Application[]
  savedBy                 SavedJob[]
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@map("jobs")
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  // Nullable until onboarding: NextAuth creates the user on first sign-in, before
  // they pick contractor (JOB_SEEKER) vs hiring (JOB_POSTER). `role == null`
  // (or onboardedAt == null) means "not yet onboarded".
  role          Role?
  posterType    PosterType?
  onboardedAt   DateTime?
  contactNumber String?
  address       String?
  dob           DateTime?
  subscription  Subscription?
  credits       Int           @default(0)

  // Contractor trust (for role = JOB_SEEKER). The verified-profile moat.
  trustTier             ContractorTrustTier          @default(SELF_DECLARED)
  holdsIR35Insurance    Boolean                      @default(false)
  ir35InsuranceProvider String? // e.g. "Qdos TLC35", "Markel Tax"
  ir35InsuranceExpiry   DateTime?
  rightToWorkConfirmed  Boolean                      @default(false)
  parsedProfile         Json? // AI-parsed CV → structured profile
  embedding             Unsupported("vector(1536)")? // semantic match; raw-SQL only

  applications      Application[]
  jobs              Job[] // jobs this user posted (role = JOB_POSTER)
  limitedCompanies  LimitedCompany[]
  documents         ContractorDocument[]
  cvs               ContractorCV[]
  savedSearches     SavedSearch[]
  savedJobs         SavedJob[]
  pushSubscriptions PushSubscription[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@map("users")
}

// How often a saved search fires its alerts.
enum AlertFrequency {
  INSTANT // as soon as new matching jobs are discovered (after aggregation)
  DAILY // once a day
  WEEKLY // once a week (Mondays)
}

// A mobile device's FCM push token, for sending native push notifications. One
// row per device (fcmToken unique); a user can have several (multi-device). The
// RN app registers its token here after sign-in; the server sends data-only FCM
// messages and prunes tokens FCM reports unregistered. Mirrors the go-unbeaten
// PushSubscription, keyed by userId (we have real users, not anon tokens).
model PushSubscription {
  id       String  @id @default(cuid())
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  fcmToken String  @unique
  platform String // 'ios' | 'android'
  timezone String  @default("UTC")
  // Master opt-out for this device. Per-alert preferences live on SavedSearch.
  enabled  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("push_subscriptions")
}

// A contractor's saved job search + email alert. Stores the same filter params as
// the /jobs board (SearchParams) as discrete columns; a daily cron finds jobs
// created since lastNotifiedAt that match and emails the contractor. We only ever
// match jobs the board would show (active + boardVisible + the IR35 rules), so an
// alert can never surface an Inside-IR35 role on this outside-IR35 board.
model SavedSearch {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // Mirrors SearchParams. Null = "no constraint on this field".
  query    String? // keyword
  location String?
  ir35     String? // 'outside' (strict) | 'any' (incl. inside) | null (default: not-inside)
  mode     String? // REMOTE | HYBRID | ON_SITE
  minRate  Int?

  // Whether the contractor wants alerts (email + push) for new matches.
  alertsEnabled  Boolean        @default(true)
  // How often alerts fire. INSTANT runs after each aggregation; DAILY/WEEKLY on
  // the daily cron. Default DAILY (matches the prior email-only behaviour).
  alertFrequency AlertFrequency @default(DAILY)
  // High-water mark: only jobs created after this are "new" for the next alert.
  lastNotifiedAt DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId])
  @@map("saved_searches")
}

// A contractor's "save for later" on a specific job. (userId, jobId) is unique so
// a save is idempotent — tapping the heart twice can't create duplicates. Both
// sides cascade-delete: removing the user or the job clears the save.
model SavedJob {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId  String

  createdAt DateTime @default(now())

  @@unique([userId, jobId])
  @@index([userId])
  @@map("saved_jobs")
}

model LimitedCompany {
  id                  String    @id @default(cuid())
  name                String
  address             String?
  // Bank details aren't needed to verify a company and aren't collected when a
  // contractor adds one (data minimisation). Nullable — captured later if ever.
  bankName            String?
  bankAccountNumber   String?
  bankSortCode        String?
  vatNumber           String
  incorporationNumber String
  // When the checkable facts last passed against official registers (we record
  // only what the gov APIs confirm — existence/active status, VAT validity).
  companyVerifiedAt   DateTime? // Companies House
  vatVerifiedAt       DateTime? // HMRC VAT / VIES
  user                User      @relation(fields: [userId], references: [id])
  userId              String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("limited_companies")
}

// A single document in a contractor's compliance pack (R2-backed, expiry-tracked).
// Mirrors the DocStatusRow UI and the T2/T3 tiers in docs/ir35-trust-model.md.
model ContractorDocument {
  id         String            @id @default(cuid())
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  type       ContractorDocType
  status     DocStatus         @default(PENDING)
  insurer    String? // for insurance docs
  coverLimit Int? // cover limit in pounds, e.g. 1000000
  expiresAt  DateTime?
  r2Key      String? // Cloudflare R2 object key (@outside-ir35-jobs/storage)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  // One document per type per contractor — lets the upload action upsert
  // (re-uploading a type replaces the existing row + R2 object).
  @@unique([userId, type])
  @@map("contractor_documents")
}

// A named CV version. Unlike compliance docs (ContractorDocument, one-per-type),
// a contractor can keep SEVERAL CVs tailored to different role-types. Each is
// parsed independently (parsedProfile). Exactly one is `isActive` — the active
// CV's parse drives User.parsedProfile + User.embedding (job matching, the pitch
// shown to posters). Uploading a new CV makes it active by default; the user can
// switch which is active. r2Key/parsedProfile are null until upload/parse complete.
model ContractorCV {
  id            String    @id @default(cuid())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  name          String // e.g. "Backend / Go", "Platform engineering"
  r2Key         String? // Cloudflare R2 object key
  status        DocStatus @default(PENDING)
  parsedProfile Json? // AI-parsed CV → structured profile (this CV's own parse)
  isActive      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@map("contractor_cvs")
}

// A contractor's premium subscription (Stripe-managed). The Stripe webhook is the
// source of truth for status/period — we never trust the client. isPremium() gates
// premium features on status=active AND currentPeriodEnd in the future.
model Subscription {
  id     String           @id @default(cuid())
  type   SubscriptionType @default(PRO)
  user   User             @relation(fields: [userId], references: [id])
  userId String           @unique

  // Which channel owns this subscription. Web subs come via Stripe; mobile subs
  // (App Store / Play Store) come via RevenueCat. One row per user — whichever
  // channel they subscribed through. `provider` drives "manage subscription"
  // routing (Stripe → billing portal; RevenueCat → the OS subscription screen).
  provider SubscriptionProvider @default(STRIPE)

  // Stripe linkage (set/updated by the Stripe webhook). customerId is reused for
  // the billing portal; subscriptionId + status + period mirror the Stripe object.
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId        String?

  // RevenueCat linkage (set/updated by the RevenueCat webhook). The app_user_id
  // RevenueCat reports IS the DB user id (RC is configured with appUserID=userId),
  // so the webhook reconciles by userId; revenueCatUserId is kept for audit/debug.
  revenueCatUserId    String? @unique
  revenueCatProductId String?

  // Mirrors the provider's subscription status, normalised to the Stripe-style
  // strings isPremium() branches on: active | trialing | past_due | canceled |
  // unpaid | incomplete. Provider-agnostic on purpose — isPremium only reads
  // status + currentPeriodEnd, so a Stripe OR RevenueCat sub unlocks identically.
  status            String    @default("incomplete")
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscriptions")
}

// Track job applications. A contractor applies to a NATIVE job with their
// verified profile (+ optional cover message); one application per job per
// applicant (the unique constraint prevents double-apply).
model Application {
  id          String    @id @default(cuid())
  jobId       String
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicantId String
  applicant   User      @relation(fields: [applicantId], references: [id])
  message     String? // optional short cover note from the contractor
  // First time the poster opened this applicant's profile. Null = not yet viewed;
  // stamped once (so the "your application was viewed" push fires exactly once).
  viewedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([jobId, applicantId])
  @@map("applications")
}
